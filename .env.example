# ── Nomba credentials ────────────────────────────────────────────────────────
NOMBA_CLIENT_ID=your_client_id_here
NOMBA_CLIENT_SECRET=your_client_secret_here
NOMBA_ACCOUNT_ID=your_account_id_here
NOMBA_BASE_URL=https://sandbox.nomba.com
NOMBA_WEBHOOK_SECRET=your_webhook_secret_here

# ── Storage ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@host/vaultnuban?sslmode=require
REDIS_URL=rediss://default:password@host:6379

# ── Reconciliation sweep ──────────────────────────────────────────────────────
SWEEP_INTERVAL=10m
SWEEP_OVERLAP=15m

# ── Internal cron auth ────────────────────────────────────────────────────────
INTERNAL_SWEEP_TOKEN=generate_a_random_secret_here

# ── CBN KYC tier limits (kobo) ────────────────────────────────────────────────
# Tier 1: ₦50k daily credit cap, ₦300k balance cap
# Tier 2: ₦200k daily credit cap, ₦5m balance cap
# Tier 3: uncapped (0 = no limit)
TIER_LIMITS_JSON={"1":{"daily_credit_kobo":5000000,"max_balance_kobo":30000000},"2":{"daily_credit_kobo":20000000,"max_balance_kobo":500000000},"3":{"daily_credit_kobo":0,"max_balance_kobo":0}}

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
ENV=development
