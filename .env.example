# ── Nomba API credentials ────────────────────────────────────────────────────
# Obtain from https://developer.nomba.com → Apps → your app → Credentials
NOMBA_CLIENT_ID=your_client_id_here
NOMBA_CLIENT_SECRET=your_client_secret_here
NOMBA_ACCOUNT_ID=your_parent_account_id_here
NOMBA_BASE_URL=https://api.nomba.com/v1
NOMBA_WEBHOOK_SECRET=your_webhook_signing_secret_here

# ── Storage ──────────────────────────────────────────────────────────────────
# Neon: Settings → Connection string → Pooled (pgbouncer) endpoint
DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require

# Upstash: Console → your database → REDIS_URL (rediss:// for TLS)
REDIS_URL=rediss://default:password@your-region.upstash.io:6379

# ── Internal auth ────────────────────────────────────────────────────────────
# Protect GET /internal/sweep — generate with: openssl rand -hex 32
INTERNAL_SWEEP_TOKEN=change_me_generate_with_openssl_rand_hex_32

# ── Reconciliation schedule ───────────────────────────────────────────────────
SWEEP_INTERVAL=10m
SWEEP_OVERLAP=15m

# ── KYC tier limits (kobo; 0 = uncapped) ─────────────────────────────────────
# Tier 1: 50k/day, 300k max | Tier 2: 200k/day, 5M max | Tier 3: uncapped
TIER_LIMITS_JSON='{"1":{"daily_credit_kobo":5000000,"max_balance_kobo":30000000},"2":{"daily_credit_kobo":20000000,"max_balance_kobo":500000000},"3":{"daily_credit_kobo":0,"max_balance_kobo":0}}'

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
ENV=development
