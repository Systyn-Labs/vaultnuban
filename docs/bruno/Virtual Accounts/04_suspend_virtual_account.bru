meta {
  name: Suspend Virtual Account
  type: http
  seq: 4
}

patch {
  url: {{base_url}}/v1/customers/{{customer_id}}/virtual-account
  body: json
  auth: bearer
}

auth:bearer {
  token: {{api_key}}
}

headers {
  Idempotency-Key: suspend-va-{{customer_id}}
  Content-Type: application/json
}

body:json {
  {
    "action": "suspend"
  }
}
